# =========================
# Postgres HA (pg_auto_failover) — Environment
# =========================

# ---- VM IPs
VM1_IP=192.168.122.18
VM2_IP=192.168.122.233
VM3_IP=192.168.122.246

# ---- Ports
# Postgres port on nodes VM1 & VM2
PG_PORT=5432

# Monitor runs on VM3:5432
MONITOR_PORT=5432

# VM3 ALSO runs a Postgres node, but the host port must NOT collide with monitor.
# Inside container it's 5432; on host we expose it as 5433.
VM3_NODE_HOST_PORT=5433

# ---- pg_auto_failover basics
FORMATION=default
AUTH_METHOD=trust
SSL_MODE=disable

# Monitor DSN used by pg_autoctl create postgres
# Note: keep ?sslmode=disable for consistency with current setup
MONITOR_DSN=postgres://autoctl_node@192.168.122.246:5432/pg_auto_failover?sslmode=disable

# ---- Container images
# Pin a version later if you want repeatability; for now matches what you used
PGAF_IMAGE=citusdata/pg_auto_failover:latest

# ---- In-container data layout (matches your running setup)
PGDATA=/var/lib/postgres/pgaf
BACKUP_DIR=/var/lib/postgres/backup

# ---- Compose directories used on the VMs (for copy/paste / scp targets)
VM_MONITOR_DIR=/home/s/db/monitor
VM_NODE_DIR=/home/s/db/node
VM_NODE3_DIR=/home/s/db/node3

# ---- Container names (as used in your setup)
MONITOR_CONTAINER=pg-monitor
NODE1_CONTAINER=pg-node1
NODE2_CONTAINER=pg-node2
NODE3_CONTAINER=pg-node3

# ---- App DSN guidance
# IMPORTANT:
# - Don't include VM3 in the same multi-host DSN because its Postgres is on host port 5433.
# - Use VM1+VM2 for write DSN with target_session_attrs=read-write.

APP_HOSTS_WRITE=192.168.122.18,192.168.122.233
APP_PORT_WRITE=5432
APP_TARGET_SESSION_ATTRS=read-write

